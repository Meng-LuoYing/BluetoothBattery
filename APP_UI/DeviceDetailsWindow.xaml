<Window x:Class="BluetoothBatteryUI.DeviceDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设备详情"
        Width="980"
        Height="660"
        WindowStartupLocation="CenterOwner"
        Background="#F3F6FA"
        Foreground="#1F2937"
        ResizeMode="CanResize">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- 导航按钮样式 -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#66FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActiveNavButton" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#80FFFFFF"/>
            <Setter Property="Foreground" Value="#0A84FF"/>
        </Style>
        
        <!-- 图标按钮样式 -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#0A84FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧导航栏 -->
            <Border x:Name="SidebarBorder" Grid.Column="0"
                    Background="#F2FFFFFF"
                    CornerRadius="18"
                    BorderBrush="#DCE3EC"
                    BorderThickness="1"
                    Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44"/>
                        <ColumnDefinition x:Name="SidebarContentColumn" Width="0"/>
                    </Grid.ColumnDefinitions>

                    <!-- 图标列 -->
                    <StackPanel Grid.Column="0">
                        <!-- 展开/收起按钮 -->
                        <Button x:Name="ToggleSidebarButton"
                                Style="{StaticResource IconButton}"
                                Click="ToggleSidebar_Click"
                                ToolTip="展开/收起">
                            <TextBlock x:Name="ToggleIcon"
                                       Text="&#xE76C;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       HorizontalAlignment="Center"/>
                        </Button>
                        
                        <!-- 时间范围图标 -->
                        <Button x:Name="TimeRangeIconButton"
                                Style="{StaticResource IconButton}"
                                Click="ToggleSidebar_Click"
                                ToolTip="时间范围">
                            <TextBlock Text="&#xE823;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       HorizontalAlignment="Center"/>
                        </Button>
                    </StackPanel>

                    <!-- 展开内容区 -->
                    <Grid x:Name="SidebarContent"
                          Grid.Column="1"
                          Margin="12,0,0,0"
                          Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,12">
                            <TextBlock x:Name="TimeRangeTitleText" Text="时间范围" FontWeight="SemiBold"/>
                        </StackPanel>

                        <Button Grid.Row="2"
                                x:Name="Range1HourButton"
                                Content="最近 1 小时"
                                Style="{StaticResource NavButton}"
                                Click="TimeRange_Click"
                                Tag="1"/>

                        <Button Grid.Row="3"
                                x:Name="Range6HourButton"
                                Content="最近 6 小时"
                                Style="{StaticResource NavButton}"
                                Click="TimeRange_Click"
                                Tag="6"/>

                        <Button Grid.Row="4"
                                x:Name="Range24HourButton"
                                Content="最近 24 小时"
                                Style="{StaticResource ActiveNavButton}"
                                Click="TimeRange_Click"
                                Tag="24"
                                VerticalAlignment="Top"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- 右侧内容区 -->
            <Grid Grid.Column="1" Margin="14,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 设备信息卡片 -->
                <Border x:Name="InfoCardBorder" Background="#F6FFFFFF"
                        CornerRadius="18"
                        Padding="18"
                        BorderBrush="#DCE3EC"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 设备名称和电量圆环 -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="DeviceNameText"
                                           Text="R65 5.0"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- 电量圆环 -->
                            <Grid Grid.Column="1" Width="74" Height="74" VerticalAlignment="Center">
                                <Ellipse Stroke="#D1D5DB" StrokeThickness="6"/>
                                <Path x:Name="BatteryArc"
                                      Stroke="#0A84FF"
                                      StrokeThickness="6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                                <TextBlock x:Name="BatteryPercentText"
                                           Text="69%"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>

                        <!-- 使用时长统计 -->
                        <Border Grid.Row="1"
                                Margin="0,12,0,0"
                                Background="#F3FFFFFF"
                                CornerRadius="14"
                                Padding="14,10"
                                BorderBrush="#DFE6EE"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="UsageTitleText" Text="使用时长统计（24h窗口）"
                                           Foreground="#64748B"
                                           FontSize="12"/>
                                <TextBlock x:Name="UsageTimeText"
                                           Text="0h 0m"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- 电量历史趋势图表 -->
                <Border x:Name="ChartCardBorder" Grid.Row="1"
                        Margin="0,16,0,0"
                        Background="#F6FFFFFF"
                        CornerRadius="18"
                        Padding="18"
                        BorderBrush="#DCE3EC"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                            <TextBlock x:Name="TrendIconText" Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="16"  Margin="0,2,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TrendTitleText" Text="电量历史走势" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Canvas x:Name="ChartCanvas"
                                    Background="Transparent"
                                    ClipToBounds="False"
                                    MouseMove="ChartCanvas_MouseMove"
                                    MouseLeave="ChartCanvas_MouseLeave"/>
                            
                            <!-- 悬浮提示层 (初始隐藏) -->
                            <Canvas x:Name="TooltipCanvas" IsHitTestVisible="False" Visibility="Collapsed">
                                <!-- 垂直指示线 -->
                                <Line x:Name="TooltipLine" 
                                      Stroke="#334155" 
                                      StrokeThickness="1" 
                                      StrokeDashArray="4 2"
                                      Opacity="0.35"
                                      Y1="0" Y2="100"/>
                                
                                <!-- 信息框 -->
                                <Border x:Name="TooltipBorder"
                                        Background="#F2FFFFFF"
                                        CornerRadius="10"
                                        Padding="8,4"
                                        Canvas.Left="0" Canvas.Top="0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#4D334155" BlurRadius="14" ShadowDepth="0"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock x:Name="TooltipTime" 
                                                   Text="13:07" 
                                                   FontSize="12" 
                                                   Foreground="#1F2937"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,2"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Rectangle x:Name="TooltipLegend" Width="8" Height="2" Fill="#0A84FF" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock x:Name="TooltipValue" 
                                                       Text="电量 68" 
                                                       FontSize="12" 
                                                       Foreground="#1F2937"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                
                                <!-- 选中点的高亮圆圈 -->
                                <Ellipse x:Name="TooltipDot"
                                         Width="10" Height="10"
                                         Stroke="White" StrokeThickness="2"
                                         Fill="#0A84FF"/>
                            </Canvas>

                            <!-- 暂无数据提示 -->
                            <TextBlock x:Name="NoDataText"
                                       Text="暂无数据"
                                       FontSize="16"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>

                        <!-- 时间标签面板 -->
                        <Canvas x:Name="TimeLabelsPanel" Grid.Row="2" Height="25" Margin="0,5,0,0" ClipToBounds="True"/>

                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 底部信息栏 -->
        <Border x:Name="FooterBorder" Grid.Row="1"
                Background="#F2FFFFFF"
                CornerRadius="14"
                Padding="12"
                Margin="0,16,0,0"
                BorderBrush="#DCE3EC"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="AvgLabelText" Text="⚡ 预估续航：" Foreground="#64748B"/>
                <TextBlock x:Name="AverageDrainText" Text="--" FontWeight="SemiBold"/>
                <TextBlock x:Name="ConnLabelText" Text="    🔗 连接方式：" Foreground="#64748B" Margin="20,0,0,0"/>
                <TextBlock x:Name="ConnectionTypeText" Text="蓝牙" FontWeight="SemiBold"/>
                <TextBlock x:Name="LastLabelText" Text="    🕐 上次变化：" Foreground="#64748B" Margin="20,0,0,0"/>
                <TextBlock x:Name="LastChangeText" Text="-" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
